{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Admin Report Schema",
    "type": "object",
    "properties": {
        "challenges": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "number" },
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "category": { "type": "string" },
                    "points": { "type": "number" },
                    "initial_points": { "type": "number" },
                    "minimum_points": { "type": "number" },
                    "solve_count": { "type": "number" },
                    "previous_challenge_id": { "type": "number" },
                    "is_active": { "type": "boolean" },
                    "stack_enabled": { "type": "boolean" },
                    "stack_target_ports": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "container_port": { "type": "number" },
                                "protocol": { "type": "string" }
                            },
                            "required": ["container_port", "protocol"]
                        }
                    },
                    "created_at": { "type": "string" },
                    "file_key": { "type": "string" },
                    "file_name": { "type": "string" },
                    "file_uploaded_at": { "type": "string" },
                    "stack_pod_spec": { "type": "string" }
                },
                "required": [
                    "id",
                    "title",
                    "description",
                    "category",
                    "points",
                    "initial_points",
                    "minimum_points",
                    "solve_count",
                    "is_active",
                    "stack_enabled",
                    "stack_target_ports",
                    "created_at"
                ]
            }
        },
        "users": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "number" },
                    "email": { "type": "string" },
                    "username": { "type": "string" },
                    "role": { "type": "string" },
                    "blocked_reason": { "type": "string" },
                    "blocked_at": { "type": "string" },
                    "created_at": { "type": "string" },
                    "updated_at": { "type": "string" }
                },
                "required": ["id", "email", "username", "role", "created_at", "updated_at"]
            }
        },
        "stacks": {
            "type": "array",
            "items": {}
        },
        "submissions": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "number" },
                    "user_id": { "type": "number" },
                    "challenge_id": { "type": "number" },
                    "correct": { "type": "boolean" },
                    "is_first_blood": { "type": "boolean" },
                    "submitted_at": { "type": "string" }
                },
                "required": ["id", "user_id", "challenge_id", "correct", "is_first_blood", "submitted_at"]
            }
        },
        "app_config": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "Key": { "type": "string" },
                    "Value": { "type": "string" },
                    "UpdatedAt": { "type": "string" }
                },
                "required": ["Key", "Value", "UpdatedAt"]
            }
        },
        "timeline": {
            "type": "object",
            "properties": {
                "submissions": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "timestamp": { "type": "string" },
                            "user_id": { "type": "number" },
                            "username": { "type": "string" },
                            "points": { "type": "number" },
                            "challenge_count": { "type": "number" }
                        },
                        "required": ["timestamp", "user_id", "username", "points", "challenge_count"]
                    }
                }
            },
            "required": ["submissions"]
        },
        "leaderboard": {
            "type": "object",
            "properties": {
                "challenges": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "number" },
                            "title": { "type": "string" },
                            "category": { "type": "string" },
                            "points": { "type": "number" }
                        },
                        "required": ["id", "title", "category", "points"]
                    }
                },
                "entries": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "user_id": { "type": "number" },
                            "username": { "type": "string" },
                            "score": { "type": "number" },
                            "solves": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "challenge_id": { "type": "number" },
                                        "solved_at": { "type": "string" },
                                        "is_first_blood": { "type": "boolean" }
                                    },
                                    "required": ["challenge_id", "solved_at", "is_first_blood"]
                                }
                            }
                        },
                        "required": ["user_id", "username", "score", "solves"]
                    }
                }
            },
            "required": ["challenges", "entries"]
        }
    },
    "required": ["challenges", "users", "stacks", "submissions", "app_config", "timeline", "leaderboard"]
}
